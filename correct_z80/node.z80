org 40000
    di
    ld hl,_j80name
    push hl
    ld hl,0
    add hl,sp
    push hl   ; argv
    ld hl,1   ; argc
    push hl
    call _main
    pop bc
    pop bc
    pop bc
    push hl
    pop bc
    ei
    ret
_j80name: db "node.c",0
_numToks:
    dw 56
names_string0:
    db "foo",0
names_string1:
    db "bar",0
_names:
    dw names_string0
    dw names_string1
_string1:
    db "int**[3]",0
_string2:
    db "%d %s\n",0
_string3:
    db "1+p[2]=%d\n",0
_string4:
    db "names=%s, %s\n",0
