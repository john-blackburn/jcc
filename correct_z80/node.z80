; =========================================
    ld hl,0
    push hl
    push iy
    pop hl
    ld bc,-8
    add hl,bc ; array
    pop de
    push hl
    ld hl,2
    call _mul_hlde
    push hl
    pop de
    pop hl
    add hl,de
    ld (iy-10),l
    ld (iy-9),h ; declare p (level 1)
