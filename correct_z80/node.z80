; malloc l=0 o=0 [void*] 
; =========================================
    ld hl,30
    ld (iy-14),l
    ld (iy-13),h ; declare j (level 1)
; =========================================
; j l=1 o=-14 [int] 
; i l=1 o=-12 [int] 
; p l=1 o=-10 [int*] 
; array l=1 o=-8 [int[3]] 
; node l=1 o=-2 [struct Node*] 
