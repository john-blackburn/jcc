; =========================================
_main:
    push iy
    ld iy,0
    add iy,sp
    ld hl,0
    add hl,sp
    ld bc,locals_main
    or a
    sbc hl,bc
    ld sp,hl
    ld hl,48
    push hl
    call _malloc
    pop bc
    ld (iy-2),l
    ld (iy-1),h ; declare node (level 1)
; =========================================
; node l=1 o=-2 [struct Node*] 
; main l=0 o=0 [int] 
; struct Node l=0 o=0 [] 
; struct Type l=0 o=0 [] 
; names l=0 o=0 [char*[]] 
; numToks l=0 o=0 [int] 
; strcpy l=0 o=0 [char*] 
; malloc l=0 o=0 [void*] 
; =========================================
    ld l,(iy-2)
    ld h,(iy-1) ; node
    ld de,0
    add hl,de ; .type
    push hl
    ld hl,10
    pop de
    push de
    pop ix
    ld (ix+0),l
    ld (ix+1),h
    ld hl,_string1
    push hl
    ld l,(iy-2)
    ld h,(iy-1) ; node
    ld de,4
    add hl,de ; .varType
    ld de,0
    add hl,de ; .data
    push hl
    call _strcpy
    pop bc
    pop bc
    ld l,(iy-2)
    ld h,(iy-1) ; node
    ld de,4
    add hl,de ; .varType
    ld de,0
    add hl,de ; .data
    push hl
    ld l,(iy-2)
    ld h,(iy-1) ; node
    ld de,0
    add hl,de ; .type
    ld c,(hl)
    inc hl
    ld b,(hl)
    push bc
    pop hl
    push hl
    ld hl,_string2
    push hl
    call _printf
    pop bc
    pop bc
    pop bc
; =========================================
