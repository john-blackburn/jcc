; strcpy l=0 o=0 [char*] 
; malloc l=0 o=0 [void*] 
; =========================================
    push iy
    pop hl
    ld bc,-14
    add hl,bc ; j
    push hl
    push iy
    pop hl
    ld bc,-12
    add hl,bc ; i
    ld e,(hl)
    inc hl
    ld d,(hl)
    dec hl
    ld c,(hl)
    inc hl
    ld b,(hl)
    inc bc
    ld (hl),b
    dec hl
    ld (hl),c
    push de
    pop hl
    push hl
    ld l,(iy-14)
    ld h,(iy-13) ; j
    pop de
    call _mul_hlde
    pop de
    push de
    pop ix
    ld (ix+0),l
    ld (ix+1),h
    push iy
    pop hl
    ld bc,-12
    add hl,bc ; i
    push hl
    push iy
    pop hl
    ld bc,-14
    add hl,bc ; j
    ld c,(hl)
    inc hl
    ld b,(hl)
    inc bc
    ld (hl),b
    dec hl
    ld (hl),c
    ld c,(hl)
    inc hl
    ld b,(hl)
    push bc
    pop hl
    pop de
    push de
    pop ix
    ld (ix+0),l
    ld (ix+1),h
    ld l,(iy-14)
    ld h,(iy-13) ; j
    push hl
    ld l,(iy-12)
    ld h,(iy-11) ; i
    pop de
    add hl,de
    ld sp,iy
    pop iy
    ret
locals_main equ 14
