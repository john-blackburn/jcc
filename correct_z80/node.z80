    push iy
    pop hl
    ld bc,-10
    add hl,bc ; p
    ld c,(hl)
    inc hl
    ld b,(hl)
    push bc
    pop hl
    pop de
    push hl
    ld hl,2
    call _mul_hlde
    push hl
    pop de
    pop hl
    add hl,de
    push hl
    ld hl,1
    pop de
    push de
    pop ix
    ld (ix+0),l
    ld (ix+1),h
    ld hl,2
    push hl
    push iy
    pop hl
    ld bc,-10
    add hl,bc ; p
    ld c,(hl)
    inc hl
    ld b,(hl)
    push bc
    pop hl
    pop de
    push hl
    ld hl,2
    call _mul_hlde
    push hl
    pop de
    pop hl
    add hl,de
    ld c,(hl)
    inc hl
    ld b,(hl)
    push bc
    pop hl
    push hl
    ld hl,1
    pop de
    add hl,de
    push hl
    ld hl,_string3
    push hl
    call _printf
    pop bc
    pop bc
    ld hl,1
    push hl
    ld hl,1
    push hl
    ld hl,_names
    pop de
    push hl
    ld hl,2
    call _mul_hlde
    push hl
    pop de
    pop hl
    add hl,de
    ld c,(hl)
    inc hl
    ld b,(hl)
    push bc
    pop hl
    pop de

    add hl,de
    push hl
    ld l,'A'
    pop de
    ld a,l
    ld (de),a
    ld hl,0
    push hl
    ld hl,1
    push hl
    ld hl,_names
    pop de
    push hl
    ld hl,2
    call _mul_hlde
    push hl
    pop de
    pop hl
    add hl,de
    ld c,(hl)
    inc hl
    ld b,(hl)
    push bc
    pop hl
