    ld hl,20
    ld (iy-12),l
    ld (iy-11),h ; declare i (level 1)
; =========================================
; i l=1 o=-12 [int] 
; p l=1 o=-10 [int*] 
; array l=1 o=-8 [int[3]] 
; node l=1 o=-2 [struct Node*] 
