; main l=0 o=0 [int] 
; malloc l=0 o=0 [void*] 
; struct _iobuf l=0 o=0 [] 
; =========================================
; =========================================
; z l=1 o=-8 [int**] 
; p l=1 o=-6 [int*] 
; m l=1 o=-4 [int] 
; n l=1 o=-2 [int] 
; main l=0 o=0 [int] 
