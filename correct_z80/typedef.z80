org 40000
    di
    ld hl,_j80name
    push hl
    ld hl,0
    add hl,sp
    push hl   ; argv
    ld hl,1   ; argc
    push hl
    call _main
    pop bc
    pop bc
    pop bc
    push hl
    pop bc
    ei
    ret
_j80name: db "typedef.c",0
_string1:
    db "sizeof FILE=%d\n",0
; =========================================
; struct _iobuf l=0 o=0 [] 
; =========================================
; =========================================
; main l=0 o=0 [int] 
; malloc l=0 o=0 [void*] 
; struct _iobuf l=0 o=0 [] 
; =========================================
_main:
    push iy
    ld iy,0
    add iy,sp
    ld hl,0
    add hl,sp
    ld bc,locals_main
    or a
    sbc hl,bc
    ld sp,hl
    ld hl,16
    push hl
    ld hl,_string1
    push hl
    call _printf
    pop bc
    pop bc
; =========================================
; n l=1 o=-2 [int] 
; main l=0 o=0 [int] 
; malloc l=0 o=0 [void*] 
; struct _iobuf l=0 o=0 [] 
